# Template for local secrets. Copy this file to ".env" and fill in real values.
# ".env" is gitignored, so your credentials never get committed.
#
# The remote SSH password for pulling files from the remote host (menu option 6).
# Precedence: environment variable REMOTE_PASSWORD > .env > config.ini.
REMOTE_PASSWORD=

# Local PostgreSQL password for Docker/migration tooling.
# Precedence: environment variable PGPASSWORD > .env > config.ini.
PGPASSWORD=change_me_local
