# Template for local secrets. Copy this file to ".env" and fill in real values.
# ".env" is gitignored, so your credentials never get committed.
#
# The remote SSH password for pulling files from the remote host (menu option 6).
# Precedence: environment variable REMOTE_PASSWORD > .env > config.ini.
REMOTE_PASSWORD=

# Local PostgreSQL password for Docker/migration tooling.
# Precedence: environment variable PGPASSWORD > .env > config.ini.
PGPASSWORD=change_me_local

# Optional Telegram push notifications. Enable with [TELEGRAM] enabled = true
# in config.ini, then set both values here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Shared secret for the Storage Map web dashboard API. Required when
# [STORAGE_MAP] web_host is not loopback; clients send it as X-Auth-Token.
STORAGE_MAP_WEB_TOKEN=

# SSH host-key trust policy for all remote operations, read at process start
# (environment variable takes precedence over .env). Default 'accept-new'
# trusts a key on first contact; set to 'yes' after provisioning known_hosts
# (ssh-keyscan) to pin keys strictly.
# LTO_SSH_HOSTKEY_POLICY=accept-new
